# ============================================
# xuexi-app 环境配置
# ============================================
# 复制此文件为 .env 并填入实际值

# ---------- 数据库配置 ----------
# PostgreSQL 连接字符串（推荐方式）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://postgres:xuexi123456@localhost:5432/xuexi

# 或分别配置（可选，如果设置了 DATABASE_URL 则优先使用）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=xuexi
# DB_USER=postgres
# DB_PASSWORD=your_secure_password

# ---------- JWT 配置 ----------
# 【重要】JWT 密钥 - 生产环境必须使用强随机字符串，禁止使用默认值！
JWT_SECRET=xuexi-super-secret-2026

# ---------- 服务器配置 ----------
PORT=8080

# ---------- CORS 配置 ----------
# 生产环境必须设置为具体的前端域名，禁止使用 *
# 示例: ALLOWED_ORIGIN=https://your-app.com
ALLOWED_ORIGIN=

# ---------- 运行环境 ----------
NODE_ENV=development
